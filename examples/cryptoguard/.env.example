# CryptoGuard Configuration

# VLM mode: "local" (load model on GPU) or "api" (OpenAI-compatible endpoint)
VLM_MODE=api

# Model ID for Qwen3-VL (used in both local and API mode)
VLM_MODEL_ID=Qwen/Qwen3-VL-7B-Instruct

# API mode settings (only used when VLM_MODE=api)
VLM_API_BASE=http://localhost:8080/v1
VLM_API_KEY=not-needed

# CLIP model for visual scam indicator scoring
CLIP_MODEL_ID=openai/clip-vit-base-patch32

# Whisper model for audio transcription
WHISPER_MODEL_ID=openai/whisper-base

# Frame extraction settings
N_FRAMES=6
GRID_COLS=3
FRAME_SIZE=384

# Video constraints
MAX_VIDEO_DURATION=180

# Server settings
HOST=0.0.0.0
PORT=8000

# Temp directory for downloaded videos
TEMP_DIR=/tmp/cryptoguard

# MExGen API Configuration
# Copy to .env and adjust as needed

MEXGEN_DEVICE=auto                              # auto | cpu | cuda | mps
MEXGEN_SUMMARIZATION_MODEL=sshleifer/distilbart-xsum-12-6
MEXGEN_QA_MODEL=google/flan-t5-base
MEXGEN_SCALARIZER=prob                          # prob | text
MEXGEN_ATTRIBUTION_METHOD=clime                 # clime | lshap | loo
MEXGEN_SPACY_MODEL=en_core_web_sm               # en_core_web_sm | en_core_web_trf
MEXGEN_OVERSAMPLING_FACTOR=10
MEXGEN_MAX_UNITS_REPLACE=2
MEXGEN_TOP_K_REFINE=3
MEXGEN_REFINE_THRESHOLD=0.33
